echo "🎨 Verificando formatação (Prettier)..."
npm run check-format || {
  echo "💥 Formatação incorreta. Rode 'npm run format', adicione as mudanças e refaça o commit."
  exit 1
}

echo "🔍 Verificando lint (ESLint)..."
npm run check-lint || {
  echo "💥 ESLint encontrou problemas. Corrija-os e refaça o commit."
  exit 1
}

echo "✏️  Verificando tipos (TypeScript)..."
npm run check-types || {
  echo "💥 Erros de tipagem encontrados. Corrija-os e refaça o commit."
  exit 1
}

echo "✅ Sem problemas de formatação, lint e tipagem. Commit liberado."
